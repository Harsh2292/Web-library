@using WebLibrary.Models
@model Product

<div class="lib-page-wrap">
    <nav class="lib-breadcrumb">
        <i class="ti ti-layout-grid"></i>
        <a asp-controller="Product" asp-action="Index">Categories</a>
        <i class="ti ti-chevron-right"></i>
        <span>Delete product</span>
    </nav>

    <div class="lib-card">
        <div class="lib-card-header">
            <div class="lib-header-icon" style="background:#FEE2E2;">
                <i class="ti ti-trash" style="color:#dc2626;"></i>
            </div>
            <div>
                <h2>Delete Product</h2>
                <p>This action cannot be undone</p>
            </div>
        </div>

        <form method="post">
            <input asp-for="Id" hidden />

            <div class="lib-card-body">
                <div class="lib-field">
                    <label asp-for="Title">Title</label>
                    <input asp-for="Title" type="text" readonly />
                </div>
                <div class="lib-field">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" type="text" readonly></textarea>
                </div>
                <div class="lib-field">
                    <label asp-for="Isbn">Isbn</label>
                    <input asp-for="Isbn" type="text" readonly />
                </div>
                <div class="lib-field">
                    <label asp-for="Author">Author</label>
                    <input asp-for="Author" type="text" readonly />
                </div>
                <div class="lib-field">
                    <label asp-for="ListPrice"></label>
                    <input asp-for="ListPrice" type="text" readonly />
                </div>
                <div class="lib-field">
                    <label asp-for="Price">Price</label>
                    <input asp-for="Price" type="text" readonly />
                </div>

                <div style="display:flex; align-items:center; gap:10px; padding:12px 14px;
                    background:#FEF2F2; border:0.5px solid #FECACA;
                    border-radius:8px; font-size:13px; color:#991b1b;">
                    <i class="ti ti-alert-triangle" style="font-size:16px; flex-shrink:0;"></i>
                    Are you sure you want to permanently delete <strong style="margin:0 3px;">@Model?.Title</strong>?
                </div>
            </div>

            <div class="lib-card-footer">
                <button type="submit" class="lib-btn-danger">
                    <i class="ti ti-trash"></i>
                    Delete product
                </button>
                <a asp-controller="Product" asp-action="Index" class="lib-btn-secondary">
                    <i class="ti ti-arrow-left"></i>
                    Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}